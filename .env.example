# ── url-destroyer 数据持久化配置 ──
# 复制此文件为 .env 后修改

# 数据库存放目录（强烈建议设为绝对路径！）
# 使用绝对路径可以确保无论从哪个目录运行 docker compose，
# 数据都在同一个位置，更新镜像也不会丢失。
# 
# 示例（Linux）：
#   DATA_DIR=/opt/url-destroyer/data
# 示例（macOS）：
#   DATA_DIR=/Users/xxx/url-destroyer/data
# 
# 不设置则默认使用当前目录下的 ./data
DATA_DIR=./data

# 数据库表名前缀（默认 ud_，表名如 ud_links, ud_settings 等）
# 设为空字符串则不使用前缀
# DB_TABLE_PREFIX=ud_
